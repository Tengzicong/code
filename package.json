{
  "name": "error-core",
  "version": "1.0.0",
  "description": "ERROR-CORE小游戏",
  "main": "main.js",
  "scripts": {
    "start": "electron --no-sandbox .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.errorcore.app",
    "productName": "ERROR-CORE小游戏",
    "mac": {
      "category": "public.app-category.games",
      "icon": "icon.icns",
      "target": [
        "zip",
        "dmg"
      ]
    },
    "dmg": {
      "sign": false,
      "iconSize": 128,
      "contents": [
        {
          "x": 340,
          "y": 250,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 160,
          "y": 250,
          "type": "file"
        }
      ],
      "window": {
        "width": 500,
        "height": 500
      }
    }
  }
}
